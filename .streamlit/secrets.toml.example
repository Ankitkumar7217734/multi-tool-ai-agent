# How to use:
#  - Local:  copy this file to .streamlit/secrets.toml and fill in your key.
#  - Cloud:  paste the line below into Streamlit Community Cloud
#            (App -> Settings -> Secrets).
#
# This is OPTIONAL. If you leave it unset, each visitor simply pastes their
# own Groq key in the sidebar. If you set it, the key is pre-filled for everyone
# (you pay for their usage), so only set it for a private/demo deployment.

GROQ_API_KEY = "gsk_your_key_here"
